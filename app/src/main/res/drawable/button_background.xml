<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Basılı durum -->

    <item android:state_pressed="true">

        <shape android:shape="rectangle">

            <solid
                android:color="@color/mavi_vurgu_koyu" />

            <corners
                android:radius="@dimen/radius_normal" />

        </shape>

    </item>

    <!-- Normal durum -->

    <item>

        <shape android:shape="rectangle">

            <gradient
                android:angle="270"
                android:endColor="#2563EB"
                android:startColor="#3B82F6" />

            <stroke
                android:width="1dp"
                android:color="#60A5FA" />

            <corners
                android:radius="@dimen/radius_normal" />

            <padding
                android:left="@dimen/padding_buyuk"
                android:top="@dimen/padding_kucuk"
                android:right="@dimen/padding_buyuk"
                android:bottom="@dimen/padding_kucuk" />

        </shape>

    </item>

</selector>