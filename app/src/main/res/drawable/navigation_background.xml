<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:angle="270"
        android:startColor="#0F172A"
        android:endColor="#111827" />

    <stroke
        android:width="1dp"
        android:color="#1E293B" />

    <corners
        android:topLeftRadius="@dimen/radius_buyuk"
        android:topRightRadius="@dimen/radius_buyuk"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />

    <padding
        android:left="@dimen/padding_normal"
        android:top="@dimen/padding_normal"
        android:right="@dimen/padding_normal"
        android:bottom="@dimen/padding_normal" />

</shape>