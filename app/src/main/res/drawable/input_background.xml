<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focus -->

    <item android:state_focused="true">

        <shape android:shape="rectangle">

            <solid
                android:color="@color/editor_arka_plan" />

            <stroke
                android:width="2dp"
                android:color="@color/mavi_vurgu" />

            <corners
                android:radius="@dimen/radius_normal" />

            <padding
                android:left="@dimen/editor_padding"
                android:top="@dimen/editor_padding"
                android:right="@dimen/editor_padding"
                android:bottom="@dimen/editor_padding" />

        </shape>

    </item>

    <!-- Normal -->

    <item>

        <shape android:shape="rectangle">

            <solid
                android:color="@color/editor_arka_plan" />

            <stroke
                android:width="1dp"
                android:color="#1E293B" />

            <corners
                android:radius="@dimen/radius_normal" />

            <padding
                android:left="@dimen/editor_padding"
                android:top="@dimen/editor_padding"
                android:right="@dimen/editor_padding"
                android:bottom="@dimen/editor_padding" />

        </shape>

    </item>

</selector>